@model RoleViewModel
@{
    ViewData["Title"] = "Edit Role";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="fas fa-edit me-2"></i> Edit Role Name
                    </h5>
                </div>

                <div class="card-body p-4">
                    <form method="post" asp-action="Edit">
                        @* الـ Id مخفي تمام *@
                        <input asp-for="Id" type="hidden" />

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold">Role Name</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="fas fa-tag text-muted"></i>
                                </span>
                                <input asp-for="Name" class="form-control" placeholder="Enter role name..." />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success px-4 shadow-sm">
                                <i class="fas fa-check me-1"></i> Update Role
                            </button>
                            <a class="btn btn-outline-secondary px-4" asp-action="Index">
                                <i class="fas fa-times me-1"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
                
                <div class="card-footer bg-light py-2">
                    <small class="text-muted">
                        <i class="fas fa-info-circle me-1"></i>
                        Changing the role name might affect users assigned to it.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}