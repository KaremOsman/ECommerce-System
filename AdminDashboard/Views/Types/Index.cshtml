@using Shared.DataTransferObject.ProductModules
@model IEnumerable<TypeDto>
@{
    ViewData["Title"] = "Types Hub";
}

@Html.AntiForgeryToken()

<link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<style>
    :root { --glass-bg: rgba(255, 255, 255, 0.7); --accent-color: #6366f1; --text-main: #1e293b; }
    body { background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%); font-family: 'Inter', sans-serif; }
    .page-header { background: var(--glass-bg); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.3); border-radius: 24px; padding: 1.5rem 2rem; margin-bottom: 2rem; box-shadow: 0 10px 30px rgba(0,0,0,0.02); }
    .brand-item { background: white; border: 1px solid rgba(0, 0, 0, 0.05); border-radius: 20px; padding: 1.25rem; margin-bottom: 12px; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); cursor: pointer; }
    .brand-item:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05); }
    .brand-item.selected-node { background: var(--accent-color); color: white !important; }
    .brand-item.selected-node .brand-name { color: white !important; }
    .mgmt-bar { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(100px); background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(15px); padding: 12px 24px; border-radius: 100px; display: flex; gap: 15px; align-items: center; transition: transform 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55); z-index: 1000; box-shadow: 0 20px 40px rgba(0,0,0,0.3); }
    .mgmt-bar.active { transform: translateX(-50%) translateY(0); }
    .brand-id-pill { background: #f1f5f9; padding: 4px 12px; border-radius: 8px; font-size: 0.75rem; font-weight: 700; color: #64748b; }
    .btn-action-hub { width: 45px; height: 45px; border-radius: 50%; border: none; display: flex; align-items: center; justify-content: center; transition: 0.2s; }
    .btn-edit-hub { background: #fbbf24; color: #000; }
    .btn-delete-hub { background: #ef4444; color: #fff; }
    .btn-action-hub:hover { transform: scale(1.15); }
    .add-floating-btn { background: var(--accent-color); color: white; padding: 12px 25px; border-radius: 16px; border: none; font-weight: 600; box-shadow: 0 10px 20px rgba(99, 102, 241, 0.2); }
</style>

<div class="container py-4">
    <div class="page-header d-flex justify-content-between align-items-center animate__animated animate__fadeInDown">
        <div>
            <h4 class="fw-bold mb-1">Types Management</h4>
            <p class="text-muted small mb-0">Total Types: <span class="badge bg-dark rounded-pill">@Model.Count()</span></p>
        </div>
        <button class="add-floating-btn shadow-sm" data-bs-toggle="modal" data-bs-target="#addBrandModal">
            <i class="fas fa-plus me-2"></i> New Type
        </button>
    </div>

    <div class="row animate__animated animate__fadeInUp">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="brand-item d-flex align-items-center shadow-sm" onclick="handleBrandSelection(this, @item.Id, '@item.Name')">
                    <div class="brand-id-pill me-3">#@item.Id</div>
                    <div class="flex-grow-1">
                        <h6 class="brand-name fw-bold mb-0 text-dark">@item.Name</h6>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div id="floatingMgmtBar" class="mgmt-bar">
    <span id="selectedLabel" class="text-white small fw-bold me-2"></span>
    <div class="vr bg-white opacity-25"></div>
    <button class="btn-action-hub btn-edit-hub" onclick="openEditModalFromHub()" title="Edit"><i class="fas fa-pen"></i></button>
    <button class="btn-action-hub btn-delete-hub" onclick="confirmDeleteFromHub()" title="Delete"><i class="fas fa-trash"></i></button>
</div>

<div class="modal fade" id="addBrandModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 24px;">
            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <h5 class="fw-bold"><i class="fas fa-plus-circle text-primary me-2"></i> Create Type</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <partial name="_CreateTypeFormPartial" model="new TypeDto()" />
            </div>
        </div>
    </div>
</div>

<partial name="_EditTypeModalPartial" model="new TypeDto()" />

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let currentSelected = { id: null, name: "" };

        // brand Selection
        function handleBrandSelection(element, id, name) {
            const isSame = element.classList.contains('selected-node');
            document.querySelectorAll('.brand-item').forEach(b => b.classList.remove('selected-node'));
            document.getElementById('floatingMgmtBar').classList.remove('active');

            if (!isSame) {
                element.classList.add('selected-node');
                currentSelected = { id, name };
                document.getElementById('selectedLabel').innerText = name.toUpperCase();
                document.getElementById('floatingMgmtBar').classList.add('active');
            } else {
                currentSelected = { id: null, name: "" };
            }
        }

        // Open Edit Modal
       function openEditModalFromHub() {
            if (!currentSelected.id) return;

             document.getElementById('editTypeId').value = currentSelected.id;
             document.getElementById('editTypeName').value = currentSelected.name;

            var modal = new bootstrap.Modal(document.getElementById('editTypeModal'));
             modal.show();
}

        // Smart Delete
        function confirmDeleteFromHub() {
            if (!currentSelected.id) return;

            Swal.fire({
                title: 'Are you sure?',
                text: `You want to delete "${currentSelected.name}"? This check for linked products first.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    
                    fetch(`/Types/Delete/${currentSelected.id}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token,
                            'Content-Type': 'application/x-www-form-urlencoded'
                        }
                    })
                    .then(response => response.json()) 
                    .then(data => {
                        if (data.success) {
                            Swal.fire({
                                title: 'Deleted!',
                                text: data.message,
                                icon: 'success',
                                timer: 1500,
                                showConfirmButton: false
                            }).then(() => location.reload());
                        } else {
                            Swal.fire({
                                title: 'Deletion Failed',
                                text: data.message,
                                icon: 'error',
                                confirmButtonColor: '#6366f1'
                            });
                        }
                    })
                    .catch(err => {
                        Swal.fire('Error', 'Communication with server failed.', 'error');
                    });
                }
            });
        }
    </script>
    
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            Swal.fire({ title: 'Success!', text: '@TempData["SuccessMessage"]', icon: 'success', confirmButtonColor: '#6366f1' });
        </script>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({ title: 'Error!', text: '@TempData["ErrorMessage"]', icon: 'error', confirmButtonColor: '#ef4444' });
        </script>
    }
}