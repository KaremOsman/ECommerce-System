@using AdminDashboard.Controllers
@model UserRoleViewModel
@{
    ViewData["Title"] = "Manage User Roles";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white d-flex align-items-center justify-content-between py-3">
                    <h5 class="mb-0">
                        <i class="fas fa-user-shield me-2"></i> Manage Roles for: <strong>@Model.UserName</strong>
                    </h5>
                    <span class="badge bg-light text-primary">ID: @Model.UserId.ToString().Substring(0, 8)...</span>
                </div>

                <div class="card-body p-4">
                    <form method="post" asp-action="Edit">
                        @* Hidden fields for Model Binding *@
                        <input asp-for="UserId" type="hidden" />
                        <input asp-for="UserName" type="hidden" />

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted">Username (Read Only)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-user"></i></span>
                                <input asp-for="UserName" class="form-control bg-light" disabled />
                            </div>
                        </div>

                        <h6 class="fw-bold mb-3"><i class="fas fa-tasks me-2"></i> Assign Roles</h6>
                        <hr class="text-muted" />

                        <div class="row g-3">
                            @for (int i = 0; i < Model.Roles.Count; i++)
                            {
                                <div class="col-md-6">
                                    <div class="form-check card p-3 border shadow-none hover-shadow transition-all">
                                        <input asp-for="@Model.Roles[i].Id" type="hidden" />
                                        <input asp-for="@Model.Roles[i].Name" type="hidden" />
                                        
                                        <div class="d-flex align-items-center justify-content-between">
                                            <label class="form-check-label fw-semibold" asp-for="@Model.Roles[i].IsSelected">
                                                @Model.Roles[i].Name
                                            </label>
                                            <div class="form-check form-switch">
                                                <input asp-for="@Model.Roles[i].IsSelected" class="form-check-input h5 mb-0" type="checkbox" role="switch">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="mt-5 d-flex gap-2">
                                <button type="submit" class="btn btn-success px-4 shadow-sm">
                                    <i class="fas fa-save me-1"></i> Save Changes
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                    <i class="fas fa-arrow-left me-1"></i> Back to List
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .hover-shadow:hover {
            background-color: #f8f9fa;
            border-color: #0d6efd !important;
            transition: all 0.3s ease;
        }
        .card { border-radius: 12px; }
        .card-header { border-radius: 12px 12px 0 0 !important; }
        .btn { border-radius: 8px; font-weight: 500; }
    </style>