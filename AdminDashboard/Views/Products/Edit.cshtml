@using Shared.DataTransferObject.ProductModules
@model CreateOrUpdateProductDto

@{
    ViewData["Title"] = "Edit Product";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />

    <style>
        body { background: #f4f6f9; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .card { border: none; border-radius: 20px; overflow: hidden; }
        .card-header { background: #fff; border-bottom: 1px solid #eee; padding: 25px; }
        .form-label { font-weight: 600; color: #444; margin-bottom: 8px; }
        .form-control, .select2-container--default .select2-selection--single {
            border-radius: 12px !important;
            border: 1px solid #e0e0e0;
            height: 45px !important;
        }
        .select2-container--default .select2-selection--single { display: flex; align-items: center; }
        .preview-box { background: #fff; border-radius: 20px; padding: 30px; text-align: center; border: 1px solid #eee; }
        .preview-img { max-width: 100%; max-height: 280px; border-radius: 15px; object-fit: cover; box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .upload-box {
            border: 2px dashed #cbd5e0;
            border-radius: 15px;
            padding: 25px;
            margin-top: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            background: #fafafa;
        }
        .upload-box:hover { border-color: #28a745; background: #f0fff4; }
        .btn-save {
            background: linear-gradient(45deg, #28a745, #20c997);
            border: none;
            border-radius: 12px;
            padding: 12px 35px;
            font-weight: 600;
            box-shadow: 0 4px 15px rgba(40, 167, 69, 0.2);
        }
        .btn-save:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(40, 167, 69, 0.3); }
    </style>
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            <div class="card shadow-lg">
                
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="fw-bold text-success mb-1">Edit Product</h3>
                        <p class="text-muted mb-0">Modify the details of your listing</p>
                    </div>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                        <i class="fas fa-times me-1"></i> Cancel
                    </a>
                </div>

                <div class="card-body p-4 p-lg-5">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        
                        <input type="hidden" name="id" value="@ViewContext.RouteData.Values["id"]" />
                        <input type="hidden" asp-for="PictureUrl" />

                        <div class="row g-5">
                            <div class="col-lg-7">
                                <div class="mb-4">
                                    <label asp-for="Name" class="form-label">Product Title</label>
                                    <input asp-for="Name" class="form-control" placeholder="Enter product name" />
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>

                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <label class="form-label">Brand</label>
                                        <select asp-for="BrandId" asp-items="ViewBag.Brands" class="form-select select2">
                                            <option></option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Category</label>
                                        <select asp-for="TypeId" asp-items="ViewBag.Types" class="form-select select2">
                                            <option></option>
                                        </select>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="Price" class="form-label">Price ($)</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0 text-muted">$</span>
                                        <input asp-for="Price" type="number" step="0.01" class="form-control border-start-0" />
                                    </div>
                                    <span asp-validation-for="Price" class="text-danger small"></span>
                                </div>

                                <div class="mb-0">
                                    <label asp-for="Description" class="form-label">Detailed Description</label>
                                    <textarea asp-for="Description" class="form-control" rows="5" placeholder="What makes this product special?"></textarea>
                                </div>
                            </div>

                            <div class="col-lg-5">
                                <div class="preview-box shadow-sm h-100">
                                    <label class="form-label d-block mb-3">Product Media</label>
                                    
                                    <div class="position-relative mb-3">
                                        <img id="previewImage"
                                             src="@(string.IsNullOrWhiteSpace(Model.PictureUrl) ? "/images/no-image.png" : Model.PictureUrl)"
                                             class="preview-img"
                                             onerror="this.src='/images/no-image.png'" />
                                    </div>

                                    <div class="upload-box" onclick="document.getElementById('fileInput').click()">
                                        <i class="fas fa-camera fa-2x text-success mb-2"></i>
                                        <p class="mb-1 fw-bold">Update Photo</p>
                                        <p class="text-muted small mb-0">Click to browse your files</p>
                                        <input asp-for="Image" type="file" id="fileInput" class="d-none" accept="image/*" />
                                    </div>
                                    
                                    <p class="text-muted mt-3 small">
                                        <i class="fas fa-info-circle me-1"></i> 
                                        Leave empty to keep the current image.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <hr class="my-5 opacity-50">

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-link text-decoration-none text-muted p-0">
                                <i class="fas fa-arrow-left me-2"></i> Back to Dashboard
                            </a>
                            <button type="submit" class="btn btn-save px-5 text-white">
                                <i class="fas fa-save me-2"></i> Commit Changes
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {
            $('.select2').select2({
                placeholder: "Search categories...",
                allowClear: true,
                width: '100%'
            });

            $('#fileInput').change(function () {
                if (this.files && this.files[0]) {
                    var reader = new FileReader();
                    reader.onload = function (e) {
                        $('#previewImage').fadeOut(200, function() {
                            $(this).attr('src', e.target.result).fadeIn(200);
                        });
                        $('.upload-box').css('border-color', '#28a745');
                    }
                    reader.readAsDataURL(this.files[0]);
                }
            });
        });
    </script>
}