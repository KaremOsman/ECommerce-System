@using Shared.DataTransferObject.ProductModules
@model CreateOrUpdateProductDto

@{
    ViewData["Title"] = "Create New Product";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />

    <style>
        body { background: #f4f6f9; font-family: 'Segoe UI', sans-serif; }
        .card { border: none; border-radius: 20px; }
        .header-gradient { background: linear-gradient(135deg,#4e73df,#224abe); color: white; padding: 25px; border-radius: 20px 20px 0 0; }
        .form-label { font-weight: 600; font-size: 0.9rem; color: #4e5d78; }
        .form-control, .select2-container--default .select2-selection--single {
            border-radius: 12px !important;
            border: 1px solid #e0e6ed;
            height: 45px !important;
        }
        .select2-container--default .select2-selection--single { display: flex; align-items: center; }
        .preview-box { background: #fff; border-radius: 20px; padding: 30px; text-align: center; border: 1px solid #e0e6ed; height: 100%; }
        .preview-img { max-width: 100%; max-height: 280px; border-radius: 15px; object-fit: cover; box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
        .upload-box {
            border: 2px dashed #cbd5e0;
            border-radius: 15px;
            padding: 25px;
            margin-top: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            background: #fafafa;
        }
        .upload-box:hover { border-color: #4e73df; background: #f8faff; }
        .btn-create {
            background: linear-gradient(45deg, #4e73df, #224abe);
            border: none;
            border-radius: 12px;
            padding: 12px 35px;
            font-weight: 600;
            transition: 0.3s;
        }
        .btn-create:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(78, 115, 223, 0.4); }
    </style>
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            <div class="card shadow-lg">
                
                <div class="header-gradient">
                    <h3 class="fw-bold mb-1"><i class="fas fa-plus-circle me-2"></i>Create New Product</h3>
                    <p class="mb-0 opacity-75">Fill in the details to list a new item in your store</p>
                </div>

                <div class="card-body p-4 p-lg-5">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                        <div class="row g-5">
                            <div class="col-lg-7">
                                <div class="mb-4">
                                    <label asp-for="Name" class="form-label">Product Name</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i class="fas fa-tag text-muted"></i></span>
                                        <input asp-for="Name" class="form-control border-start-0" placeholder="e.g. Premium Wireless Headphones" />
                                    </div>
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>

                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <label class="form-label">Brand</label>
                                        <select asp-for="BrandId" asp-items="ViewBag.Brands" class="form-select select2">
                                            <option></option>
                                        </select>
                                        <span asp-validation-for="BrandId" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Category Type</label>
                                        <select asp-for="TypeId" asp-items="ViewBag.Types" class="form-select select2">
                                            <option></option>
                                        </select>
                                        <span asp-validation-for="TypeId" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="Price" class="form-label">Selling Price</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0 fw-bold">$</span>
                                        <input asp-for="Price" type="number" step="0.01" class="form-control border-start-0" placeholder="0.00" />
                                    </div>
                                    <span asp-validation-for="Price" class="text-danger small"></span>
                                </div>

                                <div class="mb-0">
                                    <label asp-for="Description" class="form-label">Product Description</label>
                                    <textarea asp-for="Description" class="form-control" rows="5" placeholder="Describe the key features and benefits..."></textarea>
                                    <span asp-validation-for="Description" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-lg-5">
                                <div class="preview-box shadow-sm d-flex flex-column justify-content-center">
                                    <label class="form-label d-block mb-3 text-muted">Product Image Preview</label>
                                    
                                    <div class="image-container mb-3">
                                        <img id="preview" 
                                             src="/images/no-image.png" 
                                             class="preview-img @(Model?.PictureUrl == null ? "" : "")" 
                                             style="display: @(Model?.PictureUrl == null ? "inline-block" : "none");" />
                                    </div>

                                    <div class="upload-box" onclick="document.getElementById('fileInput').click()">
                                        <i class="fas fa-cloud-upload-alt fa-3x text-primary mb-3"></i>
                                        <p class="mb-1 fw-bold">Upload Product Photo</p>
                                        <p class="text-muted small mb-0">Supports: JPG, PNG, WebP</p>
                                        <input asp-for="Image" type="file" id="fileInput" class="d-none" accept="image/*" onchange="previewImage(event)" />
                                    </div>
                                    <span asp-validation-for="Image" class="text-danger small mt-2"></span>
                                </div>
                            </div>
                        </div>

                        <hr class="my-5 opacity-25">

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-link text-decoration-none text-muted p-0">
                                <i class="fas fa-arrow-left me-2"></i> Back to Products
                            </a>
                            <button type="submit" class="btn btn-create px-5 text-white">
                                <i class="fas fa-plus-circle me-2"></i> Create Product
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {
            $('.select2').select2({
                placeholder: "🔍 Search & Select",
                allowClear: true,
                width: '100%'
            });
        });

        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function () {
                var output = document.getElementById('preview');
                output.src = reader.result;
                output.style.display = "inline-block";
                $('.upload-box').css('border-color', '#4e73df');
            }
            reader.readAsDataURL(event.target.files[0]);
        }
    </script>
}