@using Shared.DataTransferObject.IdentityModules
@model LogInDto
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - System Name</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        /* General Body Styling */
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
        }

        /* Login Card Container */
        .login-card {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 24px;
            box-shadow: 0 20px 45px rgba(0, 0, 0, 0.2);
            overflow: hidden;
            width: 100%;
            max-width: 450px;
            /* Applying Fade-In Animation */
            animation: fadeIn 0.6s ease-out;
        }

        /* Crucial Fix: Use double @@ for keyframes in Razor views 
           to prevent "name does not exist" C# error.
        */
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Header Styling */
        .login-header {
            background: #ffffff;
            padding: 45px 30px 25px;
            text-align: center;
        }

        .login-header .icon-box {
            width: 85px;
            height: 85px;
            background: #f3f0ff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            color: #764ba2;
            font-size: 42px;
            box-shadow: 0 5px 15px rgba(118, 75, 162, 0.1);
        }

        /* Form Elements Styling */
        .form-control {
            border-radius: 12px;
            padding: 12px 15px;
            border: 1px solid #e2e8f0;
            background-color: #f8fafc;
            transition: all 0.2s ease;
        }

        .form-control:focus {
            box-shadow: 0 0 0 4px rgba(118, 75, 162, 0.15);
            border-color: #764ba2;
            background-color: #fff;
        }

        /* Input Groups Customization */
        .input-group-text {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            color: #64748b;
        }

        .input-group-text:first-child {
            border-radius: 12px 0 0 12px !important;
            border-right: none;
        }

        .form-control.email-input {
            border-left: none;
            border-radius: 0 12px 12px 0;
        }

        .form-control.password-field {
            border-left: none;
            border-right: none;
            border-radius: 0;
        }

        /* Password Visibility Toggle Switch */
        #togglePassword {
            cursor: pointer;
            border-radius: 0 12px 12px 0 !important;
            border-left: none;
            color: #764ba2;
            transition: all 0.2s;
        }

        #togglePassword:hover {
            background-color: #f1f5f9;
            color: #667eea;
        }

        /* Submit Button Styling */
        .btn-login {
            background: linear-gradient(135deg, #667eea, #764ba2);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 600;
            letter-spacing: 0.8px;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(118, 75, 162, 0.3);
            opacity: 0.95;
        }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="login-header">
            <div class="icon-box">
                <i class="fas fa-shield-alt"></i>
            </div>
            <h2 class="fw-bold text-dark">Admin Login</h2>
            <p class="text-muted">Enter your credentials to access the dashboard</p>
        </div>

        <div class="card-body p-4 pt-2">
            <form asp-action="LogIn" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small py-2"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold text-dark small">Email Address</label>
                    <div class="input-group shadow-sm rounded-3">
                        <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control email-input" placeholder="admin@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-semibold text-dark small">Password</label>
                    <div class="input-group shadow-sm rounded-3">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                        <input asp-for="Password" type="password" id="passwordInput" class="form-control password-field" placeholder="••••••••" />
                        <span class="input-group-text" id="togglePassword">
                            <i class="fas fa-eye"></i>
                        </span>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-login text-white">
                        SIGN IN <i class="fas fa-sign-in-alt ms-2"></i>
                    </button>
                </div>
            </form>
        </div>
    
        <div class="text-center pb-4 pt-2">
            <small class="text-muted">Lost access? <a href="#" class="text-decoration-none fw-bold" style="color: #764ba2;">Contact Administrator</a></small>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            // Function to handle the password toggle click event
            $('#togglePassword').on('click', function () {
                const passwordInput = $('#passwordInput');
                const icon = $(this).find('i');
                
                // Switching input types
                const type = passwordInput.attr('type') === 'password' ? 'text' : 'password';
                passwordInput.attr('type', type);
                
                // Switching FontAwesome eye icons
                icon.toggleClass('fa-eye fa-eye-slash');
            });
        });
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
</body>
</html>